@page "/"
@rendermode InteractiveServer

@using Microsoft.Agents.AI
@using Microsoft.Agents.AI.Hosting
@using MultiAgentSystem.AgentArtifacts

@implements IAsyncDisposable

@inject IJSRuntime JS
@inject IServiceScopeFactory ScopeFactory

<PageTitle>Chat</PageTitle>

<div class="chat-container">
    <div class="chat-messages" @ref="messagesContainer">
        @foreach (var (index, message) in messages.Index())
        {
            <div class="message @(message.IsUser ? "message-user" : "message-assistant")">
                @if (!message.IsUser)
                {
                    <div class="message-bubble">
                        @((MarkupString)FormatMessage(message.Text))
                        <div class="message-actions">
                            <button class="btn-copy" title="Copy" @onclick="() => CopyMessageAsync(message.Text, index)">
                                <Icon Type="@(copiedMessageIndex == index ? "check" : "copy")"
                                      StrokeWidth="@(copiedMessageIndex == index ? "2.5" : "2")" />
                            </button>
                        </div>
                    </div>
                }
                else
                {
                    <div class="message-bubble">@message.Text</div>
                }
            </div>
        }
        @if (isStreaming)
        {
            <div class="message message-assistant">
                @if (string.IsNullOrEmpty(streamingText))
                {
                    <div class="typing-indicator">
                        <span></span><span></span><span></span>
                    </div>
                }
                else
                {
                    <div class="message-bubble">@((MarkupString)FormatMessage(streamingText))<span class="cursor-blink">▌</span></div>
                }
            </div>
        }
    </div>

    <div class="chat-input-area" style="padding: 12px 24px 24px;">
        <div class="chat-input-wrapper">
            <textarea class="chat-input" placeholder="Ask a question..." @bind="inputText" @bind:event="oninput" @onkeydown="HandleKeyDownAsync"
                disabled="@isStreaming" rows="1" @ref="inputElement"></textarea>
            <div class="chat-buttons">
                <button class="btn-new-chat" title="New conversation" @onclick="NewConversationAsync" disabled="@isStreaming">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
                        <path d="M12 5v14M5 12h14"/>
                    </svg>
                </button>
                <button class="btn-send" title="Send message" @onclick="SendMessageAsync" disabled="@(isStreaming || string.IsNullOrWhiteSpace(inputText))">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
                        <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
                    </svg>
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    private sealed record ChatMessage(string Text, bool IsUser);

    private readonly List<ChatMessage> messages = [];
    private string inputText = string.Empty;
    private string streamingText = string.Empty;
    private bool isStreaming;
    private string conversationId = Guid.NewGuid().ToString("N");
    private ElementReference messagesContainer;
    private ElementReference inputElement;
    private int? copiedMessageIndex;
    private CancellationTokenSource? streamingCancellationTokenSource;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await FocusInputAsync();
        }
    }

    private async Task FocusInputAsync()
    {
        try
        {
            await inputElement.FocusAsync();
        }
        catch { /* ignore */ }
    }

    private async Task HandleKeyDownAsync(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey && !isStreaming && !string.IsNullOrWhiteSpace(inputText))
        {
            await SendMessageAsync();
        }
    }

    private async Task NewConversationAsync()
    {
        streamingCancellationTokenSource?.Cancel();
        messages.Clear();
        conversationId = Guid.NewGuid().ToString("N");
        streamingText = string.Empty;

        await Task.CompletedTask;
    }

    private async Task SendMessageAsync()
    {
        var text = inputText.Trim();
        if (string.IsNullOrWhiteSpace(text) || isStreaming)
        {
            return;
        }

        inputText  = string.Empty;
        messages.Add(new ChatMessage(text, true));
        isStreaming = true;
        streamingText = string.Empty;

        StateHasChanged();

        await Task.Yield();
        await ScrollToBottomAsync();

        streamingCancellationTokenSource = new CancellationTokenSource();
        var cancellationToken = streamingCancellationTokenSource.Token;

        // Each user turn runs in its own DI scope, mirroring how ASP.NET Core creates a scope per HTTP request.
        // This matters because services like AgentArtifactStore and the AIAgent itself are registered as Scoped:
        // resolving them straight from the page would tie their lifetime to the Blazor circuit (effectively a
        // singleton for the whole session), causing artifacts and agent state to leak across messages.
        await using var scope = ScopeFactory.CreateAsyncScope();
        var services = scope.ServiceProvider;

        var agent = services.GetRequiredKeyedService<AIAgent>("MainAgent");
        var sessionStore = services.GetRequiredKeyedService<AgentSessionStore>("MainAgent");
        var artifactStore = services.GetRequiredService<AgentArtifactStore>();

        try
        {
            var session = await sessionStore.GetSessionAsync(agent, conversationId, cancellationToken);

            await foreach (var update in agent.RunStreamingAsync(text, session, cancellationToken: cancellationToken))
            {
                if (string.IsNullOrEmpty(update.Text))
                {
                    continue;
                }

                streamingText += update.Text;

                StateHasChanged();
                await ScrollToBottomAsync();
            }

            await sessionStore.SaveSessionAsync(agent, conversationId, session, cancellationToken);

            messages.Add(new ChatMessage(streamingText, false));

            if (artifactStore.HasArtifacts)
            {
                // Stream artifact bytes straight to the browser via JS interop: no temporary URL or
                // server-side cache required, because the file already lives in this process' memory.
                var artifact = artifactStore.Artifacts[0];
                using var streamRef = new DotNetStreamReference(new MemoryStream(artifact.Content, writable: false));
                await JS.InvokeVoidAsync("downloadFileFromStream", cancellationToken, artifact.FileName, artifact.ContentType, streamRef);
            }
        }
        catch (OperationCanceledException)
        {
            // Page navigated away or new conversation started; nothing else to do.
        }
        catch (Exception ex)
        {
            messages.Add(new ChatMessage($"Error: {ex.Message}", false));
        }
        finally
        {
            streamingText = string.Empty;
            isStreaming = false;

            streamingCancellationTokenSource?.Dispose();
            streamingCancellationTokenSource = null;

            StateHasChanged();

            await ScrollToBottomAsync();
            await FocusInputAsync();
        }
    }

    public ValueTask DisposeAsync()
    {
        streamingCancellationTokenSource?.Cancel();
        streamingCancellationTokenSource?.Dispose();
        streamingCancellationTokenSource = null;

        return ValueTask.CompletedTask;
    }

    private async Task ScrollToBottomAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("scrollToBottom", messagesContainer);
        }
        catch { /* ignore */ }
    }

    private async Task CopyMessageAsync(string text, int index)
    {
        try
        {
            await JS.InvokeVoidAsync("copyToClipboard", text);
            copiedMessageIndex = index;
            StateHasChanged();
            await Task.Delay(2000);
            copiedMessageIndex = null;
            StateHasChanged();
        }
        catch { /* ignore */ }
    }

    private static readonly MarkdownPipeline markdownPipeline = new MarkdownPipelineBuilder().UseAdvancedExtensions().Build();

    private static string FormatMessage(string text)
        => string.IsNullOrEmpty(text) ? string.Empty : Markdown.ToHtml(text, markdownPipeline);
}
