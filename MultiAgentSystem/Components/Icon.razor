<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="@Size" height="@Size"
     fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="@StrokeWidth">
    @switch (Type)
    {
        case "copy":
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
            break;
        case "check":
            <polyline points="20 6 9 17 4 12" />
            break;
    }
</svg>

@code {
    /// <summary>
    /// Identifies which glyph to render. Currently supports <c>"copy"</c> and <c>"check"</c>;
    /// add new <c>case</c> branches above to introduce additional icons.
    /// </summary>
    [Parameter, EditorRequired]
    public required string Type { get; set; }

    /// <summary>
    /// Width and height of the rendered SVG, in pixels. Defaults to <c>14</c>.
    /// </summary>
    [Parameter]
    public int Size { get; set; } = 14;

    /// <summary>
    /// SVG <c>stroke-width</c> value. Defaults to <c>"2"</c>.
    /// </summary>
    [Parameter]
    public string StrokeWidth { get; set; } = "2";
}
